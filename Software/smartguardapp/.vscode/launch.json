{
    "configurations": [
        {
            "name": "Launch Edge",
            "request": "launch",
            "type": "msedge",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "smartguardapp (Flutter Small Phone)",
            "request": "launch",
            "type": "dart",
            "deviceId": "emulator-5554",
            "program": "lib/main.dart"
        },
        {
            "name": "smartguardapp (Chrome)",
            "request": "launch",
            "type": "dart",
            "deviceId": "chrome",
            "program": "lib/main.dart"
        }
    ]

}